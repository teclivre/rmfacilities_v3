<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_home_card_soft"
    android:padding="14dp"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp">

    <!-- Linha de título + badge "Novo" -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvTitulo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/mobile_text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:lineSpacingExtra="1dp" />

        <TextView
            android:id="@+id/tvNovo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_error"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:text="Novo"
            android:textColor="@color/white"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Conteúdo do comunicado -->
    <TextView
        android:id="@+id/tvConteudo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/mobile_text_secondary"
        android:textSize="13sp"
        android:lineSpacingExtra="2dp"
        android:layout_marginTop="6dp" />

    <!-- Data -->
    <TextView
        android:id="@+id/tvData"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/mobile_text_secondary"
        android:textSize="11sp"
        android:layout_marginTop="6dp"
        android:alpha="0.6" />
</LinearLayout>
