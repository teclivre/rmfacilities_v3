<?xml version="1.0" encoding="utf-8"?>
<!-- Balão da mensagem enviada pelo funcionário (direita) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="end"
    android:paddingStart="48dp"
    android:paddingEnd="12dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_bubble_func"
        android:padding="12dp"
        android:maxWidth="260dp">

        <TextView
            android:id="@+id/tvConteudo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#E6EEF7"
            android:textSize="14sp"
            android:lineSpacingExtra="2dp" />

        <!-- Chip de arquivo (visível só quando tipo=arquivo) -->
        <LinearLayout
            android:id="@+id/layoutArquivo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp"
            android:background="#22FFFFFF"
            android:padding="8dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#128206;"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvArquivoNome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textColor="#AACCFF"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="middle" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvHora"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="4dp"
            android:textColor="#5E7FA0"
            android:textSize="10sp" />
    </LinearLayout>
</LinearLayout>
