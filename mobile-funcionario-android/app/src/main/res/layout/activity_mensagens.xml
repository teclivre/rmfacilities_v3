<?xml version="1.0" encoding="utf-8"?>
<!--
  Activity Mensagens (Chat + Avisos) — redesign Material 3.
  IDs preservados para compatibilidade com MensagensActivity.kt.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_mobile_gradient">

    <!-- ── Header (status-bar safe) ─────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="52dp"
        android:paddingBottom="10dp"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVoltar"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:minHeight="40dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="← Voltar"
            android:textColor="@color/mobile_text_primary"
            android:textSize="14sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Mensagens"
            android:textColor="@color/mobile_text_primary"
            android:textSize="19sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.01" />

        <TextView
            android:id="@+id/tvBadge"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:background="@drawable/bg_badge_error"
            android:gravity="center"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <!-- ── Abas Chat / Avisos (segmented Material 3) ───────────────────── -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="10dp"
        app:cardBackgroundColor="@color/mobile_surface_soft"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/mobile_card_stroke"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="4dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTabChat"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="Chat"
                android:textSize="14sp"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="none"
                android:includeFontPadding="false"
                app:cornerRadius="11dp"
                app:elevation="0dp"
                app:icon="@drawable/ic_chat"
                app:iconSize="18dp"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                app:iconTint="@android:color/white"
                app:backgroundTint="@color/mobile_tab_active"
                android:textColor="@android:color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTabAvisos"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="Avisos"
                android:textSize="14sp"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="none"
                android:includeFontPadding="false"
                app:cornerRadius="11dp"
                app:elevation="0dp"
                app:icon="@drawable/ic_megaphone"
                app:iconSize="18dp"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                app:iconTint="@color/mobile_text_primary"
                app:backgroundTint="@android:color/transparent"
                android:textColor="@color/mobile_text_primary" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ── Status última resposta RH (pílula sutil) ───────────────────── -->
    <TextView
        android:id="@+id/tvStatusRh"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="6dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:background="@drawable/bg_chat_file_chip_rh"
        android:textColor="@color/mobile_tab_active"
        android:textSize="11sp"
        android:textStyle="bold"
        android:gravity="center"
        android:visibility="gone" />

    <!-- ── Painel Chat ─────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/panelChat"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeChat"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMensagens"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:clipToPadding="false"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"
                android:scrollbars="none" />
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <ProgressBar
            android:id="@+id/progressEnvio"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:indeterminate="true"
            android:visibility="gone"
            android:progressTint="@color/mobile_tab_active" />

        <!-- Composer card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/mobile_card_surface"
            app:cardCornerRadius="22dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/mobile_card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvCharCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:paddingEnd="16dp"
                    android:paddingTop="6dp"
                    android:text="0/1000"
                    android:textSize="10sp"
                    android:textColor="@color/mobile_text_secondary"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="4dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAnexar"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="44dp"
                        android:minWidth="0dp"
                        android:layout_height="44dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"
                        app:icon="@drawable/ic_attach"
                        app:iconSize="22dp"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconTint="@color/mobile_text_secondary"
                        app:backgroundTint="@android:color/transparent"
                        app:cornerRadius="22dp" />

                    <EditText
                        android:id="@+id/etMensagem"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="Digite sua mensagem…"
                        android:textColorHint="@color/mobile_text_secondary"
                        android:textColor="@color/mobile_text_primary"
                        android:textSize="14.5sp"
                        android:padding="10dp"
                        android:minHeight="44dp"
                        android:maxLines="4"
                        android:maxLength="1000"
                        android:inputType="textMultiLine|textCapSentences"
                        android:imeOptions="actionSend|flagNoEnterAction" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEnviar"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="44dp"
                        android:minWidth="0dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="6dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"
                        app:icon="@drawable/ic_send"
                        app:iconSize="20dp"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconTint="@android:color/white"
                        app:backgroundTint="@color/mobile_tab_active"
                        app:cornerRadius="22dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- ── Painel Avisos ───────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/panelAvisos"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAvisos"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:clipToPadding="false"
            android:paddingTop="4dp"
            android:paddingBottom="8dp"
            android:scrollbars="none" />

        <TextView
            android:id="@+id/tvAvisosVazio"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Nenhum comunicado ainda."
            android:textColor="@color/mobile_text_secondary"
            android:textSize="14sp"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
