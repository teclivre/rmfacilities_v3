<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_mobile_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="52dp"
        android:paddingBottom="16dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <TextView
            android:id="@+id/btnVoltar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="‹"
            android:textColor="@color/mobile_text_primary"
            android:textSize="30sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Configurações"
                android:textColor="@color/mobile_text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Formulário de preferências e segurança"
                android:textColor="@color/mobile_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_widget">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Segurança"
                    android:textColor="@color/mobile_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchBiometriaConfig"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:text="Entrar com biometria"
                    android:textColor="@color/mobile_text_primary"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tvBiometriaStatusConfig"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="10dp"
                    android:background="@drawable/bg_home_card_soft"
                    android:textColor="@color/mobile_text_secondary"
                    android:textSize="12sp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchNotificacoesConfig"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    android:text="Receber notificações push"
                    android:textColor="@color/mobile_text_primary"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:background="@drawable/bg_home_card_soft"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Aparência"
                    android:textColor="@color/mobile_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rgTemaApp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rbTemaClaro"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:gravity="center_vertical"
                        android:text="Tema claro (padrão)"
                        android:textColor="@color/mobile_text_primary"
                        android:textSize="15sp" />

                    <RadioButton
                        android:id="@+id/rbTemaEscuro"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:gravity="center_vertical"
                        android:text="Tema escuro"
                        android:textColor="@color/mobile_text_primary"
                        android:textSize="15sp" />

                    <RadioButton
                        android:id="@+id/rbTemaSistema"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:gravity="center_vertical"
                        android:text="Seguir tema do sistema"
                        android:textColor="@color/mobile_text_primary"
                        android:textSize="15sp" />
                </RadioGroup>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:background="@drawable/bg_home_card_soft"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Canal para código de acesso"
                    android:textColor="@color/mobile_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rgCanalOtp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rbCanalWhatsapp"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:gravity="center_vertical"
                        android:text="WhatsApp"
                        android:textColor="@color/mobile_text_primary"
                        android:textSize="15sp" />

                    <RadioButton
                        android:id="@+id/rbCanalEmail"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:gravity="center_vertical"
                        android:text="E-mail"
                        android:textColor="@color/mobile_text_primary"
                        android:textSize="15sp" />
                </RadioGroup>

                <TextView
                    android:id="@+id/tvCanalOtpStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/mobile_semantic_info"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvFeedbackConfig"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_home_card_soft"
                android:padding="12dp"
                android:text="As alterações são aplicadas automaticamente."
                android:textColor="@color/mobile_text_secondary"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:background="@drawable/bg_home_card_soft"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bloqueio por inatividade"
                    android:textColor="@color/mobile_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rgTimeoutSessao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rbTimeout10"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:gravity="center_vertical"
                        android:text="10 minutos"
                        android:textColor="@color/mobile_text_primary"
                        android:textSize="15sp" />

                    <RadioButton
                        android:id="@+id/rbTimeout15"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:gravity="center_vertical"
                        android:text="15 minutos"
                        android:textColor="@color/mobile_text_primary"
                        android:textSize="15sp" />

                    <RadioButton
                        android:id="@+id/rbTimeout30"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:gravity="center_vertical"
                        android:text="30 minutos"
                        android:textColor="@color/mobile_text_primary"
                        android:textSize="15sp" />
                </RadioGroup>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical"
                android:paddingBottom="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRevogarDispositivo"
                    style="@style/Widget.App.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Revogar dispositivo confiável"
                    android:textColor="@color/mobile_semantic_pending"
                    app:strokeColor="@color/mobile_card_border" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogoutRemoto"
                    style="@style/Widget.App.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:text="Sair deste aparelho"
                    android:textColor="@color/mobile_semantic_info"
                    app:strokeColor="@color/mobile_card_border" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPoliticaPrivacidade"
                    style="@style/Widget.App.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:text="Política de privacidade"
                    android:textColor="@color/mobile_text_secondary"
                    app:strokeColor="@color/mobile_card_border" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLimparOffline"
                    style="@style/Widget.App.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:text="Limpar documentos offline"
                    android:textColor="@color/mobile_text_secondary"
                    app:strokeColor="@color/mobile_card_border" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
