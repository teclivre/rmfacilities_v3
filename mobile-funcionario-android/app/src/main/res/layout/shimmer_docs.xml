<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:paddingTop="8dp">

    <!-- Placeholder item 1 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/surface">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">
            <View android:layout_width="44dp" android:layout_height="44dp"
                android:background="@drawable/bg_shimmer_item"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="14dp"
                android:orientation="vertical">
                <View android:layout_width="160dp" android:layout_height="14dp"
                    android:background="@drawable/bg_shimmer_item"/>
                <View android:layout_width="90dp" android:layout_height="10dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_shimmer_item"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

