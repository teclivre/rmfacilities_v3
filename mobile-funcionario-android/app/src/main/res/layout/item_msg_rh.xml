<?xml version="1.0" encoding="utf-8"?>
<!--
  Balão de mensagem do RH (alinhado à esquerda) — redesign Material 3.
  IDs preservados: tvRemetente, tvConteudo, tvHora, layoutArquivo, tvArquivoNome.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="start"
    android:paddingStart="12dp"
    android:paddingEnd="56dp"
    android:paddingTop="3dp"
    android:paddingBottom="3dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="2dp"
        app:cardBackgroundColor="@color/mobile_bubble_rh_bg"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="RH"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold" />
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/mobile_card_surface"
        app:cardCornerRadius="16dp"
        app:cardElevation="1dp"
        app:strokeColor="@color/mobile_card_stroke"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tvRemetente"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RH"
                android:textColor="@color/mobile_tab_active"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingBottom="2dp" />

            <TextView
                android:id="@+id/tvConteudo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/mobile_text_primary"
                android:textSize="14.5sp"
                android:lineSpacingExtra="2dp" />

            <LinearLayout
                android:id="@+id/layoutArquivo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_chat_file_chip_rh"
                android:paddingStart="10dp"
                android:paddingEnd="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#128206;"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tvArquivoNome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:maxWidth="200dp"
                    android:textColor="@color/mobile_tab_active"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="middle" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvHora"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="4dp"
                android:textColor="@color/mobile_text_secondary"
                android:textSize="10sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
