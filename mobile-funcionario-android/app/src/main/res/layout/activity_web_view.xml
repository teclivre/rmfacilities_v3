<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/mobile_background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/mobile_surface"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVoltarWebView"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Voltar"
            android:textColor="@color/mobile_text_primary"
            android:minWidth="0dp"
            android:paddingStart="4dp"
            android:paddingEnd="8dp"/>

        <TextView
            android:id="@+id/tvWebViewTitulo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/mobile_text_primary"
            android:maxLines="1"
            android:ellipsize="end"
            android:paddingEnd="8dp"/>
    </LinearLayout>

    <!-- Barra de progresso -->
    <ProgressBar
        android:id="@+id/progressWebView"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:max="100"
        android:visibility="gone"
        android:progressTint="@color/mobile_tab_active"/>

    <!-- WebView -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
