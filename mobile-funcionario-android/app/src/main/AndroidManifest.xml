<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.CAMERA" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:name=".RMFuncionarioApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name_version"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RMFuncionarioApp"
        android:usesCleartextTraffic="false">

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <activity
            android:name=".PagamentosActivity"
            android:exported="false" />
        <activity
            android:name=".FeriasActivity"
            android:exported="false" />
        <activity
            android:name=".SolicitacaoCorrecaoPontoActivity"
            android:exported="false" />
        <activity
            android:name=".CorrecoesPontoActivity"
            android:exported="false" />
        <activity
            android:name=".AlteracoesCadastraisActivity"
            android:exported="false" />
        <activity
            android:name=".DocumentosActivity"
            android:exported="false"
            android:launchMode="singleTop" />
        <activity
            android:name=".PrivacyPolicyActivity"
            android:exported="false" />
        <activity
            android:name=".PdfPreviewActivity"
            android:exported="false" />
        <activity
            android:name=".HistoricoAssinaturasActivity"
            android:exported="false" />
        <activity
            android:name=".PerfilActivity"
            android:exported="false"
            android:launchMode="singleTop" />
        <activity
            android:name=".MensagensActivity"
            android:exported="false"
            android:launchMode="singleTop" />
        <activity
            android:name=".PontoActivity"
            android:exported="false"
            android:launchMode="singleTop" />
        <activity
            android:name=".PontoMapaActivity"
            android:exported="false" />
        <activity
            android:name=".PontoHistoricoActivity"
            android:exported="false" />
        <activity
            android:name=".PontoEspelhoActivity"
            android:exported="false" />
        <activity
            android:name=".AboutActivity"
            android:exported="false" />
        <activity
            android:name=".ConfiguracoesActivity"
            android:exported="false" />
        <activity
            android:name=".WebViewActivity"
            android:exported="false" />
        <activity
            android:name=".HomeActivity"
            android:exported="true"
            android:launchMode="singleTop" />
        <activity
            android:name=".LoginActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".FcmService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>

</manifest>
